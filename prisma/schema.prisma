generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(uuid())
  first_name         String
  last_name          String
  email              String   @unique
  password_hash      String
  phone              String?
  street1            String?
  street2            String?
  city               String?
  state              String?
  zip                String?
  country            String?
  profile_image      String?
  stripe_customer_id String?
  stripe_account_id  String?
  seller_enabled     Boolean  @default(false)
  is_admin           Boolean  @default(false)
  is_disabled        Boolean  @default(false)
  email_verified     Boolean   @default(true)
  reset_token        String?   @unique
  reset_token_expiry DateTime?
  welcome_seen_at    DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  listings           Listing[]
  purchases          Purchase[] @relation("BuyerPurchases")
  cartItems          CartItem[]
  favoriteItems      FavoriteItem[]
  reviewedListings   Listing[]  @relation("ListingReviewer")
  reviewsReceived    SellerReview[] @relation("SellerReviewsReceived")
  reviewsWritten     SellerReview[] @relation("SellerReviewsWritten")
  buyerConversations Conversation[] @relation("ConversationBuyer")
  sellerConversations Conversation[] @relation("ConversationSeller")
  sentConversationMessages ConversationMessage[] @relation("ConversationMessageSender")
  followers          Follow[] @relation("UserFollowing")
  following          Follow[] @relation("UserFollowers")
  drafts             Draft[]
  notifications      Notification[] @relation("UserNotifications")
  aiCoverJobs        AICoverJob[]
  refreshTokens      RefreshToken[]
  deviceTokens       DeviceToken[]
  listingPromotions   ListingPromotion[]
  promotionInvitations PromotionInvitation[]
  deleted_at         DateTime?
  deletion_scheduled_purge_at DateTime?
}

model Notification {
  id         String    @id @default(uuid())
  user_id    String
  user       User      @relation("UserNotifications", fields: [user_id], references: [id], onDelete: Cascade)
  type       String    // ITEM_SOLD, ITEM_DELIVERED (v1) — extensible
  title      String
  body       String
  link_url   String?
  read_at    DateTime?
  created_at DateTime  @default(now())

  @@index([user_id, created_at])
  @@index([user_id, read_at])
}

model Draft {
  id                   String   @id @default(uuid())
  user_id              String
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  title                String?
  style                String?
  category             String?
  subcategory          String?
  type                 String?
  price                String?
  brand                String?
  description          String?
  condition            String?
  size                 String?
  measurements         String?
  photo_urls           String[]
  generated_image_urls String[]
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([user_id, updated_at])
}

model Listing {
  id                String    @id @default(uuid())
  user_id           String
  user              User      @relation(fields: [user_id], references: [id])
  title             String
  description       String
  price             Decimal
  image_url         String
  images            ListingImage[]
  view_count        Int       @default(0)
  style             String
  category          String
  subcategory       String?
  type              String?
  condition         String?
  brand             String?
  size              String?
  status            String    @default("AVAILABLE") // AVAILABLE, SOLD
  moderation_status String    @default("PENDING")   // PENDING, APPROVED, PARTIAL_APPROVED, REJECTED
  is_featured       Boolean   @default(false)       // curation: surfaces on Home "Featured" rail when true
  featured_order    Int?                            // admin-set sort order for the Home "Featured" rail; lower first, NULLs last
  reviewed_at       DateTime?
  reviewed_by_id    String?
  reviewedBy        User?     @relation("ListingReviewer", fields: [reviewed_by_id], references: [id])
  rejection_reason  String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  purchases         Purchase[]
  cartItems         CartItem[]
  favoriteItems     FavoriteItem[]
  conversations     Conversation[]
  listingPromotions ListingPromotion[]

  @@index([status, moderation_status, created_at])
  @@index([style, category, subcategory, type])
  @@index([size])
  @@index([price])
}

model PendingUser {
  id                     String    @id @default(uuid())
  first_name             String
  last_name              String
  email                  String    @unique
  password_hash          String
  phone                  String?
  street1                String?
  street2                String?
  city                   String?
  state                  String?
  zip                    String?
  country                String?
  verification_code_hash String
  code_expiry            DateTime
  attempt_count          Int       @default(0)
  resend_count           Int       @default(0)
  last_sent_at           DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
}

model Purchase {
  id                String   @id @default(uuid())
  buyer_id          String
  buyer             User     @relation("BuyerPurchases", fields: [buyer_id], references: [id])
  listing_id        String
  listing           Listing  @relation(fields: [listing_id], references: [id])
  amount            Decimal
  // For bundle checkouts, N Purchase rows share one stripe_session_id +
  // payment_intent_id (one Stripe session covers multiple items). The
  // per-column @unique constraints we had before made this impossible —
  // the 2nd insert always violated. We use composite unique on
  // (stripe_session_id, listing_id) instead, which:
  //   1. Allows N rows per session (one per listing in the bundle)
  //   2. Still gives idempotency: a duplicate insert for the same
  //      (session, listing) pair throws P2002, which our checkout finalizer
  //      catches and treats as ALREADY_FINALIZED.
  stripe_session_id String?
  payment_intent_id String?
  created_at        DateTime @default(now())
  order             Order?

  // Promotion audit trail — null when purchase happened outside any campaign.
  // When set, `amount` is the discounted price the buyer paid; `original_amount`
  // is what the listing would have cost without the promo. Recorded at
  // checkout-finalize time so historical purchases stay accurate even if
  // the campaign later gets edited/cancelled.
  original_amount        Decimal?
  discount_amount        Decimal?
  promotion_campaign_id  String?
  promotion_campaign     PromotionCampaign? @relation(fields: [promotion_campaign_id], references: [id])

  @@unique([stripe_session_id, listing_id])
  @@unique([payment_intent_id, listing_id])
}

model Order {
  id              String    @id @default(uuid())
  purchase_id     String    @unique
  purchase        Purchase  @relation(fields: [purchase_id], references: [id])
  order_status    String    @default("PAID")         // PENDING, PAID, FULFILLED, CANCELLED, REFUNDED
  shipping_status String    @default("NOT_SHIPPED")  // NOT_SHIPPED, PROCESSING, SHIPPED, DELIVERED, CANCELLED, RETURNED
  shipping_stage  String    @default("ADDRESS_MISSING") // ADDRESS_MISSING, ADDRESS_SET, OPTION_SELECTED, LABEL_PURCHASED
  shipping_address Json?
  shipping_option_rate_id      String?
  shipping_option_carrier      String?
  shipping_option_service      String?
  shipping_option_amount       String?
  shipping_option_currency     String?
  shipping_option_selected_at  DateTime?
  carrier               String?
  tracking_number       String?
  shippo_transaction_id String?
  label_url             String?
  shipped_at            DateTime?
  delivered_at          DateTime?
  hold_until            DateTime?
  seller_transfer_status String   @default("PENDING_HOLD") // PENDING_HOLD, READY_FOR_RELEASE, RELEASED, BLOCKED, FAILED, AWAITING_SELLER_STRIPE
  seller_transfer_id     String?
  seller_transfer_amount_cents Int?
  seller_transfer_currency String?
  seller_transfer_released_at DateTime?
  unclaimed_reminder_sent_at DateTime?
  // Refund / cancel state. Populated by admin's refundOrder() / cancelOrder()
  // server actions. order_status flips to "REFUNDED" or "CANCELLED" when these
  // fire; the columns below capture WHO / WHEN / WHY for auditability.
  refund_id                    String?     // Stripe refund id (re_...)
  refunded_at                  DateTime?
  refund_reason                String?     // duplicate / fraudulent / requested_by_customer / other
  refund_note                  String?     // free-text admin note
  refund_initiator_id          String?     // admin user id who pressed the button
  // If the seller transfer was already RELEASED at the time of refund, we
  // pull funds back from the seller's connected account via transfers.createReversal.
  seller_transfer_reversed_at  DateTime?
  seller_transfer_reversal_id  String?     // Stripe transfer reversal id (trr_...)
  // Shippo label refund. When a buyer's order is refunded, we ask Shippo to
  // refund the (often unused) shipping label too — succeeds when the carrier
  // hasn't scanned the label yet, denied otherwise. Status is usually QUEUED
  // initially and lands on SUCCESS / DECLINED / ERROR via the transaction_updated
  // webhook. Errors are stored so admin can see why a refund attempt failed.
  shippo_label_refund_id      String?
  shippo_label_refunded_at    DateTime?
  shippo_label_refund_status  String?     // QUEUED | PENDING | SUCCESS | DECLINED | ERROR
  shippo_label_refund_error   String?
  // Soft link for same-seller bundled checkout. NULL = legacy single-item order.
  // When set, Orders sharing this id ship in one parcel with one Shippo label
  // and one tracking number — the seller buys the label once and all sibling
  // Orders inherit the label_url / tracking_number / shipping_status.
  batch_id              String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  @@index([seller_transfer_status])
  @@index([batch_id])
  @@index([refunded_at])
}

model ListingImage {
  id          String   @id @default(uuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  imageUrl    String
  thumbUrl    String?
  mediumUrl   String?
  imageOrder  Int
  createdAt   DateTime @default(now())

  @@index([listingId, imageOrder])
  @@unique([listingId, imageOrder])
}

model CartItem {
  id                  String    @id @default(uuid())
  user_id             String
  listing_id          String
  user                User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  listing             Listing   @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  created_at          DateTime  @default(now())
  // Idempotency stamps for the cart-abandonment reminder cron at
  // /api/internal/remind-abandoned-carts. `first` lands at 48h since add;
  // `second` lands 7 days after the first reminder fired. Both are
  // null while the row is still "pending reminder" so the WHERE clause
  // can use a simple IS NULL check.
  first_reminded_at   DateTime?
  second_reminded_at  DateTime?

  @@unique([user_id, listing_id])
  @@index([user_id, created_at])
  @@index([first_reminded_at, created_at])
  @@index([second_reminded_at, first_reminded_at])
}

model FavoriteItem {
  id         String   @id @default(uuid())
  user_id    String
  listing_id String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  listing    Listing  @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@unique([user_id, listing_id])
  @@index([user_id, created_at])
}

model SellerReview {
  id          String   @id @default(uuid())
  seller_id   String
  seller      User     @relation("SellerReviewsReceived", fields: [seller_id], references: [id], onDelete: Cascade)
  reviewer_id String
  reviewer    User     @relation("SellerReviewsWritten", fields: [reviewer_id], references: [id], onDelete: Cascade)
  rating      Int
  text        String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([seller_id, reviewer_id])
  @@index([seller_id, created_at])
  @@index([reviewer_id, created_at])
}

model Conversation {
  id         String   @id @default(uuid())
  buyer_id   String
  seller_id  String
  listing_id String?
  buyer      User     @relation("ConversationBuyer", fields: [buyer_id], references: [id], onDelete: Cascade)
  seller     User     @relation("ConversationSeller", fields: [seller_id], references: [id], onDelete: Cascade)
  listing    Listing? @relation(fields: [listing_id], references: [id], onDelete: SetNull)
  messages   ConversationMessage[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([buyer_id, seller_id])
  @@index([buyer_id, updated_at])
  @@index([seller_id, updated_at])
}

model ConversationMessage {
  id               String       @id @default(uuid())
  conversation_id  String
  sender_id        String
  body             String
  image_url        String?
  read_at          DateTime?
  created_at       DateTime     @default(now())
  // Idempotency stamp for the unread-message reminder cron at
  // /api/internal/remind-unread-messages. Set once when the digest
  // email containing this message has been sent; the cron's WHERE
  // clause uses (read_at IS NULL AND reminder_sent_at IS NULL AND
  // created_at < NOW() - 24h).
  reminder_sent_at DateTime?
  // Idempotency stamp for the "you got a new message" email cron at
  // /api/internal/send-new-message-emails. Email fires ~5 min after
  // arrival if the message is still unread, so active conversations
  // don't generate per-message email spam. Set once the email is sent.
  email_sent_at    DateTime?
  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender           User         @relation("ConversationMessageSender", fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at])
  @@index([sender_id, created_at])
  @@index([conversation_id, read_at])
  @@index([read_at, reminder_sent_at, created_at])
  @@index([read_at, email_sent_at, created_at])
}

model Follow {
  id           String   @id @default(uuid())
  follower_id  String
  following_id String
  follower     User     @relation("UserFollowers", fields: [follower_id], references: [id], onDelete: Cascade)
  following    User     @relation("UserFollowing", fields: [following_id], references: [id], onDelete: Cascade)
  created_at   DateTime @default(now())

  @@unique([follower_id, following_id])
  @@index([follower_id])
  @@index([following_id])
}

// AI cover generation jobs — submitted by sellers from the sell page. Decoupled
// from the request lifecycle so the cover keeps generating even if the seller
// closes their tab. See plan: /Users/qasimjaveed/.claude/plans/...joyful-hoare.md
// (Async AI cover generation).
//
// Lifecycle: QUEUED → PROCESSING → COMPLETED / FAILED / TIMEOUT
// - QUEUED: submitted, waiting for the in-process worker (or cron sweeper).
// - PROCESSING: worker has picked it up, OpenAI call in flight.
// - COMPLETED: result_image_url set, completed_at stamped, notification fired.
// - FAILED: error_message set; notification fired with friendly copy.
// - TIMEOUT: cron sweeper marked it FAILED with "Timed out" after >5 min in
//   PROCESSING (stuck worker, process crash, etc.).
model AICoverJob {
  id                   String    @id @default(uuid())
  user_id              String
  user                 User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  draft_id             String?   // soft link to the listing draft this job is for
  status               String    @default("QUEUED")
  // Input snapshot — exactly what we'll send to OpenAI
  title                String
  category             String
  subcategory          String?
  style                String
  size                 String?
  description          String
  hijab_required       Boolean   @default(false)
  model_skin_tone      String
  reference_image_keys String[]                       // S3 keys for uploaded refs, in slot order
  // Output
  result_image_url     String?
  error_message        String?
  // Tracking
  attempts             Int       @default(0)
  started_at           DateTime?
  completed_at         DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  @@index([user_id, status, created_at])
  @@index([status, created_at])
}

// Refresh tokens issued by /api/v1/auth/login for the mobile (Flutter) client.
// Stored as a sha256 hash so a stolen DB row can't be replayed against the
// auth endpoint. Rotation on /api/v1/auth/refresh marks the old row's
// revoked_at and inserts a new one — that gives us refresh-token rotation
// detection (if a revoked token is presented, the chain is compromised and
// we can mass-revoke the user's other sessions).
//
// Web continues to use NextAuth cookie sessions; this table is mobile-only.
model RefreshToken {
  id         String    @id @default(uuid())
  user_id    String
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token_hash String    @unique                  // sha256 of the opaque random token
  device_id  String?                            // optional client-supplied device fingerprint
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())
  last_used_at DateTime?

  @@index([user_id, revoked_at])
  @@index([expires_at])
}

// One row per active install of the Flutter app per user. FCM token is the
// natural key — Firebase rotates them, so re-registers UPSERT on token.
// Revoked rows are kept (no hard delete) so we can audit which devices were
// active when a notification was queued.
model DeviceToken {
  id          String    @id @default(uuid())
  user_id     String
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token       String    @unique           // FCM device token, opaque to us
  platform    String                       // "ios" | "android"
  app_version String?
  created_at  DateTime  @default(now())
  last_seen_at DateTime @default(now())
  revoked_at  DateTime?

  @@index([user_id, revoked_at])
}

// Push-notification outbox. createNotification() inserts here after writing
// the in-app Notification row; the /api/internal/dispatch-push-notifications
// cron drains it via FCM. Decoupling the FCM call from the request path:
//   - keeps createNotification fast (no external API in the hot path)
//   - gives us free retries (exponential backoff via next_attempt_at)
//   - survives Firebase being temporarily down or misconfigured
// Successfully-sent rows are kept for ~30 days for debuggability, then
// purged by the same cron.
model NotificationOutbox {
  id              String    @id @default(uuid())
  notification_id String                                  // FK soft-link to Notification.id
  user_id         String                                  // denormalized for fan-out per device
  type            String                                  // mirrors Notification.type
  title           String
  body            String
  data            Json?                                   // extra payload (e.g., {jobId, listingId})
  attempts        Int       @default(0)
  next_attempt_at DateTime  @default(now())
  sent_at         DateTime?
  failed_reason   String?
  created_at      DateTime  @default(now())

  @@index([sent_at, next_attempt_at])
  @@index([user_id, sent_at])
}

// Time-boxed marketing campaigns (e.g. "Myrtle Summer 2026 — 15% off"). A
// listing joins a campaign via ListingPromotion. Discount only applies while
// status = "ACTIVE" AND NOW() is inside [starts_at, ends_at]. Expired
// campaigns automatically stop discounting without any code changes — the
// getEffectivePrice helper gates on these fields.
model PromotionCampaign {
  id                 String    @id @default(uuid())
  name               String                                // "Myrtle Summer Sale"
  slug               String    @unique                     // "myrtle-summer-2026" — used for idempotent script re-runs
  discount_type      String    @default("PERCENT")         // PERCENT (FLAT is future work)
  discount_percent   Int                                   // 15 for 15% off
  status             String    @default("DRAFT")           // DRAFT, ACTIVE, ENDED, CANCELLED
  starts_at          DateTime
  ends_at            DateTime
  target_rules_json  Json?                                 // { titleContains: ["Myrtle"], brandContains: ["Myrtle"] }
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  listingPromotions  ListingPromotion[]
  invitations        PromotionInvitation[]
  purchases          Purchase[]

  @@index([status, starts_at, ends_at])
}

// Join between a campaign and a listing. Rows start as INVITED when the
// generator script runs; the seller flips them to ACCEPTED or DECLINED on
// the /promotions/approve/[token] page. Unique on (campaign, listing) so
// re-running the script is idempotent.
model ListingPromotion {
  id                    String    @id @default(uuid())
  promotion_campaign_id String
  listing_id            String
  seller_id             String
  status                String    @default("INVITED")      // INVITED, ACCEPTED, DECLINED, REMOVED, EXPIRED
  discount_percent      Int                                 // snapshot from campaign at invite time
  invited_at            DateTime  @default(now())
  accepted_at           DateTime?
  declined_at           DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  promotion_campaign    PromotionCampaign @relation(fields: [promotion_campaign_id], references: [id], onDelete: Cascade)
  listing               Listing           @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  seller                User              @relation(fields: [seller_id], references: [id], onDelete: Cascade)

  @@unique([promotion_campaign_id, listing_id])
  @@index([listing_id, status])
  @@index([seller_id, promotion_campaign_id])
}

// One row per seller per campaign. token_hash is sha256(plaintext); the
// plaintext lives only in the invitation URL and email. Unique on
// (campaign, seller) so a seller can't have two active invites for the
// same campaign — script re-runs update timestamps instead of duplicating.
model PromotionInvitation {
  id                    String    @id @default(uuid())
  promotion_campaign_id String
  seller_id             String
  token_hash            String    @unique
  expires_at            DateTime                            // defaults to campaign.starts_at
  email_sent_at         DateTime?
  first_opened_at       DateTime?
  created_at            DateTime  @default(now())

  promotion_campaign    PromotionCampaign @relation(fields: [promotion_campaign_id], references: [id], onDelete: Cascade)
  seller                User              @relation(fields: [seller_id], references: [id], onDelete: Cascade)

  @@unique([promotion_campaign_id, seller_id])
  @@index([expires_at])
}
